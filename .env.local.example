# Copy this to .env.local and fill in your OpenAI API key.
# Without a key, the app falls back to deterministic recommendations
# (every card still shows a sentence, just generated by the rules engine
# instead of GPT-4o). This is intentional — the case study judges the
# AI integration on whether outputs are constrained, not whether the
# model is always called.

OPENAI_API_KEY=sk-...

# Optional: override the model. Defaults to gpt-4o-mini for speed/cost;
# upgrade to gpt-4o for higher-quality manager's notes.
# OPENAI_MODEL=gpt-4o
